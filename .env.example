# =============================================================================
# Realty Tunax — Canonical Monorepo Environment Reference
# =============================================================================
# This file documents ALL environment variables used across the monorepo.
# It is the single source of truth for the env contract.
#
# HOW TO USE:
#   Local dev:   Copy the per-app .env.example files to their respective
#                .env / .env.local files (all gitignored). Fill in real values.
#   Production:  Set these variables directly in your hosting panel or secret
#                manager. Never commit files with real secrets.
#
# PER-APP EXAMPLES:
#   apps/api/.env.example     — API and Worker variables
#   apps/web/.env.example     — Next.js web variables
#   apps/mobile/.env.example  — Expo mobile variables (if applicable)
#
# SECRET vs PUBLIC:
#   Secret  — server-only, never exposed to browsers or mobile clients
#   Public  — safe to expose; baked into browser/mobile bundles at build time
#             (prefixed NEXT_PUBLIC_ for web, EXPO_PUBLIC_ for mobile)
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# CORE
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development                     # development | production | test
PORT=3001                                # API HTTP port

# ─────────────────────────────────────────────────────────────────────────────
# CORS  (API)  — SECRET scope: server-only
# ─────────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
# Production: CORS_ORIGINS=https://tunax.com,https://www.tunax.com

# ─────────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS  (API)
# ─────────────────────────────────────────────────────────────────────────────
FEATURE_SWAGGER_ENABLED=true    # Must be false or absent in production
FEATURE_SEED_USERS=true         # Must be false or absent in production

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE  (API)  — SECRET
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:5432/YOUR_DB_NAME
# Production: postgresql://user:pass@managed-host:5432/db?sslmode=require

# ─────────────────────────────────────────────────────────────────────────────
# REDIS  (API + Worker)  — SECRET
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Production: rediss://user:pass@managed-redis:6380   (rediss = TLS)

# ─────────────────────────────────────────────────────────────────────────────
# INTERNAL SERVICE AUTH  (API + Worker + Web proxy)  — SECRET
# ─────────────────────────────────────────────────────────────────────────────
# API accepts: comma-separated list (supports key rotation overlap)
INTERNAL_API_KEYS=change-me-internal-key
# Worker and Web use the single active key:
INTERNAL_API_KEY=change-me-internal-key
# Worker also needs the API base URL:
INTERNAL_API_BASE_URL=http://localhost:3001
# Generate: openssl rand -hex 32

# ─────────────────────────────────────────────────────────────────────────────
# JWT  (API)  — SECRET
# ─────────────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-at-least-32-chars-minimum-random
JWT_ACCESS_TOKEN_EXPIRES_IN=24h
# Production: use 1h, generate via: openssl rand -base64 48

# ─────────────────────────────────────────────────────────────────────────────
# AWS S3  (API)  — SECRET
# ─────────────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=eu-north-1
AWS_BUCKET_NAME=YOUR_S3_BUCKET_NAME
# Optional: CloudFront or custom CDN base URL for public media reads
# S3_PUBLIC_BASE_URL=https://cdn.yourdomain.com

# ─────────────────────────────────────────────────────────────────────────────
# WEB — PUBLIC (browser-safe, NEXT_PUBLIC_ prefix required)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=Realty Tunax
# NEXT_PUBLIC_S3_CDN_BASE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# WEB — SERVER-ONLY (no NEXT_PUBLIC_ prefix — safe, never in browser bundle)
# ─────────────────────────────────────────────────────────────────────────────
API_BASE_URL_SERVER=http://localhost:3001

# ─────────────────────────────────────────────────────────────────────────────
# MOBILE  (Expo)  — PUBLIC (safe for mobile clients, EXPO_PUBLIC_ prefix)
# ─────────────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001

# ─────────────────────────────────────────────────────────────────────────────
# DOCKER COMPOSE (local dev only)  — SECRET
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=tunax
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=tunax
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin-password
