# =============================================================================
# Realty Tunax — Web (Next.js) Environment Variables
# Copy this file to .env.local (gitignored) and fill in values for local dev.
# In production, set these in your hosting panel (Vercel, Railway, etc.)
#
# VALIDATION STRATEGY:
#   Build-time  — next.config.ts checks NEXT_PUBLIC_* vars only (baked into bundle)
#   Runtime     — lib/api/client.ts validates API_BASE_URL_SERVER & INTERNAL_API_KEY
#                 when they are first used (per-request, not at build time)
#   CI          — set NEXT_PUBLIC_API_BASE_URL=http://localhost:3001 in the build
#                 step env; server-only vars are NOT needed during `next build`
# =============================================================================

# ── Public (browser-safe) — baked into Next.js bundle at build time ───────────
# WARNING: Any NEXT_PUBLIC_ variable is visible to all users in the browser.
# Never put secrets, API keys, or internal credentials here.
# REQUIRED at build time: next.config.ts throws if this is absent.
# CI safe: http://localhost:3001 is an acceptable placeholder for compilation.

# Base URL of the NestJS API — used by browser fetch calls
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# App display name (used in UI)
NEXT_PUBLIC_APP_NAME=Realty Tunax

# Optional: public CDN base URL for S3 media (e.g. CloudFront)
# If not set, the API derives the URL from the bucket name.
# NEXT_PUBLIC_S3_CDN_BASE_URL=

# ── Server-only — never exposed to the browser ────────────────────────────────
# These vars have NO NEXT_PUBLIC_ prefix. Next.js keeps them server-side only.
# They are accessible in Route Handlers and Server Components.
# NOT required at `next build` time — only validated when first used at runtime.

# Internal API base URL — used by Next.js proxy routes when calling the API
# In production: can point to an internal network address (e.g. http://api:3001)
API_BASE_URL_SERVER=http://localhost:3001

# Internal API key for admin-guarded backend endpoints.
# Must match a value in the backend INTERNAL_API_KEYS env var.
# Generate: openssl rand -hex 32
INTERNAL_API_KEY=change-me-internal-key
