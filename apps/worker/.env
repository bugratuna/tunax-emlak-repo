NODE_ENV=development

# Redis — must match API's REDIS_URL
REDIS_URL=redis://localhost:6379

# Internal API key — must match one entry in API's INTERNAL_API_KEYS
INTERNAL_API_KEY=dev-internal-key-001

# API base URL (no trailing slash)
INTERNAL_API_BASE_URL=http://localhost:3001

# Optional: BullMQ worker concurrency (default 1)
WORKER_CONCURRENCY=1
