# NestJS (API)
PORT=3001
NODE_ENV=development

# Redis — required (BullMQ automation queue)
REDIS_URL=redis://localhost:6379

# Internal service auth — required (worker → API)
# Comma-separated; supports multiple keys for rotation overlap
INTERNAL_API_KEYS=dev-internal-key-001

# Database — required
# Primary DB is arep_postgis (postgis/postgis:16-3.4) on host port 5432.
# Do NOT point this at arep_postgres_db (postgres:17) on port 5433 — no PostGIS extension there.
DATABASE_URL=postgresql://tunax:tunax123@localhost:5432/tunax

# JWT — required (API-1)
JWT_ACCESS_SECRET=change-me-access-32-chars-minimum
JWT_ACCESS_TOKEN_EXPIRES_IN=24h

# Dev seed users — created automatically on boot when NODE_ENV=development
# Never seeded in production.
# admin@arep.local   / Admin123!      → role ADMIN
# consultant@arep.local / Consultant123! → role CONSULTANT

# AWS S3 — required for listing media upload
# WARNING: never commit real credentials; rotate any key that was committed.

AWS_ACCESS_KEY_ID=AKIA4NKQYDGQTLYVZTSW
AWS_SECRET_ACCESS_KEY=lsQ3G2aTrqmqkKh+AS4b6CsmxEVPeQkXXpUZ1fRd
AWS_REGION=eu-north-1
AWS_BUCKET_NAME=tunax-repo
# Optional: override the public base URL (e.g. CloudFront domain).
# Defaults to https://{AWS_BUCKET_NAME}.s3.{AWS_REGION}.amazonaws.com
# S3_PUBLIC_BASE_URL=https://tunax-repo.s3.eu-north-1.amazonaws.com
