# NestJS (API)
PORT=3001
NODE_ENV=development

# Redis — required (BullMQ automation queue)
REDIS_URL=redis://localhost:6379

# Internal service auth — required (worker → API)
# Comma-separated; supports multiple keys for rotation overlap
INTERNAL_API_KEYS=dev-internal-key-001

# Database (not yet wired — commented out until Prisma phase)
# DATABASE_URL=postgresql://tunax:tunax123@localhost:5432/tunax

# JWT (not yet enforced — commented out until auth phase)
# JWT_ACCESS_SECRET=change-me-access-32-chars-minimum
# JWT_REFRESH_SECRET=change-me-refresh-32-chars-minimum

# S3 (not yet wired)
# S3_REGION=eu-central-1
# S3_BUCKET=tunax-assets
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
