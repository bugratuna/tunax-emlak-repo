# =============================================================================
# Realty Tunax — API Environment Variables
# Copy this file to .env (gitignored) and fill in real values for local dev.
# In production, set these directly in your hosting panel or secret manager.
# NEVER commit real secrets. Rotate any key that was ever committed to git.
# =============================================================================

# ── Core ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. In production: https://yourdomain.com
CORS_ORIGINS=http://localhost:3000

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set FEATURE_SWAGGER_ENABLED=true to expose /api/docs (dev only).
# Must be false or absent in production.
FEATURE_SWAGGER_ENABLED=true
# Set FEATURE_SEED_USERS=true to create dev seed accounts on boot.
# Must be false or absent in production.
FEATURE_SEED_USERS=true

# ── Database ──────────────────────────────────────────────────────────────────
# Required. PostGIS container (postgis/postgis:16-3.4) on port 5432.
# Production: add ?sslmode=require
DATABASE_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:5432/YOUR_DB_NAME

# ── Redis ─────────────────────────────────────────────────────────────────────
# Required. Production: use rediss:// (TLS)
REDIS_URL=redis://localhost:6379

# ── Internal Service Auth ─────────────────────────────────────────────────────
# Required. Comma-separated; supports multiple keys for zero-downtime rotation.
# Must match INTERNAL_API_KEY used by worker and web proxy.
# Generate: openssl rand -hex 32
INTERNAL_API_KEYS=change-me-internal-key

# ── JWT ───────────────────────────────────────────────────────────────────────
# Required. Minimum 32 characters. Use a cryptographically random value.
# Generate: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-at-least-32-chars-minimum-random
# Optional. Default: 24h in dev, recommend 1h in production.
JWT_ACCESS_TOKEN_EXPIRES_IN=24h

# ── AWS S3 (listing media upload) ─────────────────────────────────────────────
# Required. Use a dedicated IAM user with s3:PutObject/GetObject/DeleteObject
# scoped to your bucket only. NEVER use root credentials.
# Generate new key: AWS IAM Console -> Users -> Security credentials -> Create key
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=eu-north-1
AWS_BUCKET_NAME=YOUR_S3_BUCKET_NAME
# Optional: override public base URL (e.g. CloudFront domain).
# Defaults to https://{AWS_BUCKET_NAME}.s3.{AWS_REGION}.amazonaws.com
# S3_PUBLIC_BASE_URL=https://cdn.yourdomain.com
